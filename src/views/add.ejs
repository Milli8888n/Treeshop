<%- include('partials/header') %>

<div class="min-h-screen py-20 px-8 flex items-center justify-center bg-surface relative overflow-hidden">
    <!-- Decorative elements from design -->
    <div class="absolute -top-24 -right-24 w-96 h-96 opacity-10 pointer-events-none">
        <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuD62X3ifnsWhpp4_8hKYqh7RNhLSOEYIJdNuhKwUvBKrVy5ZrqXEQcF_0z-vSue07tDmkCFeNor5fjuJqXxOLPuKBp2dsv1CjxiZ6GOSaoATT-oYo76ObFcTPHE3dnR6GhqdqAcauYpnQ0m4D7vdUTVRQG-NsvoiGhHwYnZPPipFW1kk215paTkwcFzspjARFz_uerl4gpjuGpaSMiuWbFReaqcNq_31jMhynnzFZCalx_tK4G_ReifNfrhIrEyKVk1sdWtQ4xkgPaA" class="w-full h-full object-contain">
    </div>

    <div class="relative w-full max-w-4xl bg-white/70 glass-nav rounded-[40px] shadow-2xl overflow-hidden border border-white/40 flex flex-col md:flex-row">
        <!-- Hero Section -->
        <div class="md:w-5/12 bg-teal-900 relative min-h-[400px] flex flex-col justify-end p-10 overflow-hidden">
            <div class="absolute inset-0 bg-gradient-to-br from-teal-950 to-teal-800 opacity-90 mix-blend-multiply"></div>
            <img class="absolute inset-0 w-full h-full object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBzYHZFpuqk0BV4QZFKUA__OiQV233PWNBD91i1o1kO4Pw6_Izyxn23T0r6SvcXtfnBgHLs87qaiyx3yi1Nxks3tEFfCg-ihvQzsrpiLTicBVDaeZVRJpT17qdySm0IRz9ARBDKjzk8GAkkzNzjj9ks8S3Pa4yNeVibkv-_yvo2Oxj2FgXHYVi9x-AaHVXLyXkUNxD_2jlMuq3zHbadzBqOMiG8MmXO8F0HG6m_n_QE5XtAzWr0tiv0ogx_-Ecv5DKY58hIVnQ0tb17">
            <div class="relative z-10 space-y-4">
                <span class="inline-block px-3 py-1 rounded-full bg-teal-200 text-teal-900 text-[10px] uppercase font-bold tracking-widest">Inventory Expansion</span>
                <h1 class="text-4xl font-extrabold text-white headline tracking-tighter leading-tight">Catalogue a New Specimen</h1>
                <p class="text-teal-100/70 text-sm leading-relaxed max-w-xs">Add your latest botanical discovery to the atelier’s curated digital glasshouse.</p>
            </div>
        </div>

        <!-- Form Section -->
        <div class="md:w-7/12 p-12 bg-white flex flex-col justify-center">
            <div class="mb-10">
                <h2 class="text-3xl font-bold text-teal-900 headline tracking-tight">Plant Profile</h2>
                <p class="text-sm text-zinc-400 font-medium">Detailed botanical documentation</p>
            </div>

            <form action="/add" method="POST" class="space-y-8">
                <div class="group">
                    <label class="block text-[10px] uppercase tracking-widest font-bold text-zinc-400 mb-2 group-focus-within:text-teal-700 transition-colors" for="treename">Plant Name</label>
                    <input name="treename" id="treename" type="text" required 
                           class="w-full bg-zinc-50 border-b-2 border-zinc-100 focus:border-teal-700 focus:outline-none py-3 px-1 transition-all text-zinc-900 placeholder:text-zinc-300" 
                           placeholder="e.g. Alocasia Macrorrhiza">
                </div>

                <div class="group">
                    <label class="block text-[10px] uppercase tracking-widest font-bold text-zinc-400 mb-2 group-focus-within:text-teal-700 transition-colors" for="description">Description</label>
                    <textarea name="description" id="description" rows="3" required
                              class="w-full bg-zinc-50 border-b-2 border-zinc-100 focus:border-teal-700 focus:outline-none py-3 px-1 transition-all text-zinc-900 placeholder:text-zinc-300 resize-none" 
                              placeholder="Describe growth habits, light requirements..."></textarea>
                </div>

                <div class="group">
                    <label class="block text-[10px] uppercase tracking-widest font-bold text-zinc-400 mb-2 group-focus-within:text-teal-700 transition-colors" for="image">Image URL</label>
                    <div class="flex items-center bg-zinc-50 border-b-2 border-zinc-100 focus-within:border-teal-700 transition-all">
                        <span class="material-symbols-outlined text-zinc-300 px-3">link</span>
                        <input name="image" id="image" type="url" 
                               class="w-full bg-transparent border-none focus:ring-0 py-3 px-1 text-zinc-900 placeholder:text-zinc-300" 
                               placeholder="https://images.unsplash.com/...">
                    </div>
                </div>

                <div class="pt-6 flex items-center gap-6">
                    <button type="submit" class="flex-1 py-4 bg-teal-800 text-white rounded-2xl font-bold text-lg shadow-xl shadow-teal-900/20 hover:bg-teal-700 active:scale-95 transition-all flex items-center justify-center gap-3">
                        <span class="material-symbols-outlined">add_circle</span>
                        Catalogue Specimen
                    </button>
                    <a href="/" class="text-zinc-400 font-bold hover:text-teal-700 transition-colors text-sm border-b-2 border-transparent hover:border-teal-100 py-1">
                        Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

<%- include('partials/footer') %>
