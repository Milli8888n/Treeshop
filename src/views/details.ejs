<%- include('partials/header') %>

<div class="px-8 md:px-12 py-20 max-w-[1920px] mx-auto min-h-[80vh]">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
        <!-- Image Section -->
        <div class="sticky top-28">
            <div class="rounded-[50px] overflow-hidden shadow-2xl bg-zinc-50 aspect-[4/5] relative group">
                <img src="<%= tree.image %>" 
                     alt="<%= tree.treename %>" 
                     class="w-full h-full object-cover">
                <!-- Floating Badge -->
                <div class="absolute top-8 left-8 bg-white/80 backdrop-blur-md px-6 py-2 rounded-full shadow-lg">
                    <span class="text-xs font-bold uppercase tracking-widest text-teal-800 headline">Curated Specimen</span>
                </div>
            </div>
        </div>

        <!-- Content Section -->
        <div class="flex flex-col h-full pt-8">
            <!-- Breadcrumbs -->
            <nav class="flex gap-2 text-zinc-400 text-sm mb-8 headline">
                <a href="/" class="hover:text-teal-600">Home</a>
                <span>/</span>
                <span class="text-teal-900 font-semibold">Details</span>
            </nav>

            <h1 class="text-6xl md:text-8xl font-black text-teal-950 headline tracking-tighter leading-none mb-8">
                <%= tree.treename %>
            </h1>

            <div class="flex gap-4 mb-12">
                <div class="bg-teal-50 px-6 py-4 rounded-3xl border border-teal-100 flex flex-col">
                    <span class="text-[10px] uppercase font-bold text-teal-700 tracking-wider mb-1">Status</span>
                    <span class="text-teal-900 font-bold headline">In Collection</span>
                </div>
                <div class="bg-zinc-50 px-6 py-4 rounded-3xl border border-zinc-100 flex flex-col">
                    <span class="text-[10px] uppercase font-bold text-zinc-400 tracking-wider mb-1">Catalog ID</span>
                    <span class="text-zinc-900 font-bold headline">#<%= tree._id.toString().slice(-6).toUpperCase() %></span>
                </div>
            </div>

            <div class="prose prose-zinc prose-lg max-w-none mb-16">
                <h3 class="text-teal-900 font-bold headline mb-4">Botanical Description</h3>
                <p class="text-zinc-500 leading-huge text-xl">
                    <%= tree.description %>
                </p>
            </div>

            <div class="mt-auto grid grid-cols-2 gap-6 pb-12">
                <div class="bg-white p-8 rounded-[40px] shadow-sm border border-zinc-100">
                    <span class="material-symbols-outlined text-teal-700 mb-4">wb_sunny</span>
                    <h4 class="font-bold text-teal-950 headline mb-2">Ideal Light</h4>
                    <p class="text-zinc-500 text-sm">Bright, indirect sunlight is optimal for growth.</p>
                </div>
                <div class="bg-white p-8 rounded-[40px] shadow-sm border border-zinc-100">
                    <span class="material-symbols-outlined text-teal-700 mb-4">water_drop</span>
                    <h4 class="font-bold text-teal-950 headline mb-2">Moisture</h4>
                    <p class="text-zinc-500 text-sm">Maintain consistent humidity levels (60%+).</p>
                </div>
            </div>

            <div class="pt-8 border-t border-zinc-100 flex gap-4">
                <a href="/" class="flex-1 py-5 bg-teal-800 text-white rounded-[25px] font-bold text-center shadow-xl shadow-teal-950/20 hover:scale-[1.02] active:scale-95 transition-all">
                    Back to Collection
                </a>
                <button class="px-8 py-5 border-2 border-zinc-100 rounded-[25px] hover:bg-zinc-50 transition-all active:scale-95">
                    <span class="material-symbols-outlined">share</span>
                </button>
            </div>
        </div>
    </div>
</div>

<%- include('partials/footer') %>
