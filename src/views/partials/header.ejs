<!DOCTYPE html>
<html class="light" lang="en">
<head>
    <meta charset="utf-8"/>
    <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
    <title>TreeShop | Botanical Atelier</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;600;700;800&family=Inter:wght@300;400;500;600&family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
    <style>
        body { font-family: 'Inter', sans-serif; }
        h1, h2, h3, .headline { font-family: 'Manrope', sans-serif; }
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        .glass-nav {
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
        }
        .bg-surface { background-color: #f9faf5; }
        .text-on-surface { color: #1a1c19; }
        .text-primary { color: #006565; }
        .bg-primary { background-color: #006565; }
        .text-on-primary { color: #ffffff; }
    </style>
</head>
<body class="bg-surface text-on-surface">
    <!-- TopNavBar -->
    <nav class="fixed top-0 w-full z-50 bg-white/80 glass-nav shadow-sm">
        <div class="flex justify-between items-center px-8 md:px-12 h-20 max-w-[1920px] mx-auto">
            <!-- Brand Logo -->
            <div class="text-2xl font-bold tracking-tighter text-teal-900 headline">
                TreeShop
            </div>
            <!-- Navigation Links -->
            <div class="hidden md:flex gap-10 items-center">
                <a class="text-teal-700 border-b-2 border-teal-600 pb-1 font-semibold transition-all" href="/">Home</a>
                <a class="text-zinc-600 hover:text-teal-600 transition-colors" href="/add">Add Tree</a>
                <a class="text-zinc-600 hover:text-teal-600 transition-colors" href="/about">About Us</a>
                <form action="/reset" method="POST" style="display: inline;">
                    <button type="submit" class="text-red-600 hover:text-red-800 transition-colors font-medium">Reset Store</button>
                </form>
            </div>
            <!-- Trailing Icons -->
            <div class="flex items-center gap-6 text-teal-800">
                <button class="hover:text-teal-600 transition-all duration-300 transform active:scale-95">
                    <span class="material-symbols-outlined">search</span>
                </button>
                <button class="hover:text-teal-600 transition-all duration-300 transform active:scale-95">
                    <span class="material-symbols-outlined">shopping_bag</span>
                </button>
                <button class="md:hidden">
                    <span class="material-symbols-outlined">menu</span>
                </button>
            </div>
        </div>
    </nav>
    <main class="pt-20">
